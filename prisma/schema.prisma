datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Customer {
  id        String    @id @default(uuid())
  email     String    @unique
  firstName String?
  lastName  String?
  phone     String?
  tags      String[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  messages  Message[]
  tasks     Task[]
}

model Message {
  id                      String   @id @default(uuid())
  customerId              String
  source                  String
  direction               String
  subject                 String
  body                    String
  messageType             String
  priority                String
  sentiment               String
  requiresHumanValidation Boolean
  externalId              String?
  sourceAccount           String?
  createdAt               DateTime @default(now())

  customer                Customer @relation(fields: [customerId], references: [id])

  @@unique([source, externalId])
}

model Task {
  id          String   @id @default(uuid())
  customerId  String?
  taskType    String
  title       String
  description String?
  status      String   @default("pending")
  priority String @default("MEDIUM")
  dueAt       DateTime?
  createdAt   DateTime @default(now())

  customer Customer? @relation(fields: [customerId], references: [id])
}

model Event {
  id          String   @id @default(uuid())
  eventType   String
  entityType  String
  entityId    String
  payload     Json
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  processedAt DateTime?
}