datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Customer {
  id        String    @id @default(uuid())
  email     String    @unique
  firstName String?
  lastName  String?
  phone     String?
  tags      String[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  messages  Message[]
  tasks     Task[]
}

model Message {
  id                      String   @id @default(uuid())
  customerId              String
  source                  String
  direction               String
  subject                 String
  body                    String
  messageType             String
  priority                String
  sentiment               String
  requiresHumanValidation Boolean
  externalId              String?
  sourceAccount           String?
  createdAt               DateTime @default(now())

  customer                Customer @relation(fields: [customerId], references: [id])

  @@unique([source, externalId])
}

model Task {
  id          String   @id @default(uuid())
  customerId  String?
  taskType    String
  title       String
  description String?
  status      String   @default("pending")
  priority String @default("MEDIUM")
  dueAt       DateTime?
  createdAt   DateTime @default(now())

  customer Customer? @relation(fields: [customerId], references: [id])
}

model Event {
  id          String   @id @default(uuid())
  eventType   String
  entityType  String
  entityId    String
  payload     Json
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  processedAt DateTime?
}

model IgnoredSender {
  id        String   @id @default(uuid())
  email     String   @unique
  reason    String?
  createdAt DateTime @default(now())
}

model MarketCompetitor {
  id        String   @id @default(uuid())
  name      String
  website   String?
  address   String?
  region    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offers MarketOffer[]
}

model MarketOffer {
  id           String   @id @default(uuid())
  competitorId String
  domain       String
  title        String?
  description  String?
  price        Float?
  currency     String?
  duration     String?
  ageMin       Int?
  ageMax       Int?
  location     String?
  schedule     String?
  groupSize    Int?
  status       String   @default("UNKNOWN")
  sourceUrl    String?
  confidence   Float?
  detectedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  competitor MarketCompetitor @relation(fields: [competitorId], references: [id])
  history    MarketOfferHistory[]
}

model MarketOfferHistory {
  id         String   @id @default(uuid())
  offerId    String
  price      Float?
  status     String
  capturedAt DateTime @default(now())

  offer MarketOffer @relation(fields: [offerId], references: [id])
}

model MarketScan {
  id         String    @id @default(uuid())
  domain     String
  region     String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  status     String

  extractedData MarketExtractedData[]
}

model MarketExtractedData {
  id           String   @id @default(uuid())
  marketScanId String
  competitor   String
  domain       String
  rawContent   String
  parsedData   Json?
  confidence   Float?
  sourceUrl    String
  createdAt    DateTime @default(now())

  marketScan MarketScan @relation(fields: [marketScanId], references: [id])
}

model MarketAlert {
  id         String   @id @default(uuid())
  type       String
  message    String
  domain     String
  competitor String?
  createdAt  DateTime @default(now())
  isRead     Boolean  @default(false)
}

model PhoenixService {
  id             String   @id @default(uuid())
  code           String   @unique
  name           String
  category       String
  estimatedValue Float    @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bookings      PhoenixBooking[]
  activities    PhoenixActivity[]
  sessions      PhoenixSession[]
  opportunities PhoenixOpportunity[]
}

model PhoenixFamily {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  people        PhoenixPerson[]
  bookings      PhoenixBooking[]
  registrations PhoenixRegistration[]
  opportunities PhoenixOpportunity[]
}

model PhoenixPerson {
  id              String   @id @default(uuid())
  type            String
  firstName       String?
  lastName        String?
  stageName       String?
  email           String?
  phone           String?
  birthDate       DateTime?
  entryDate       DateTime?
  address         String?
  magicLevel      String?
  parentFirstName String?
  parentLastName  String?
  normalizedEmail String?
  normalizedPhone String?
  familyId        String?
  organizationId  String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  family              PhoenixFamily?       @relation(fields: [familyId], references: [id], onDelete: SetNull)
  organization        PhoenixOrganization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  childBookings       PhoenixBooking[]     @relation("PhoenixBookingChild")
  parentBookings      PhoenixBooking[]     @relation("PhoenixBookingParent")
  childRegistrations  PhoenixRegistration[] @relation("PhoenixRegistrationChild")
  parentRegistrations PhoenixRegistration[] @relation("PhoenixRegistrationParent")
  personOpportunities PhoenixOpportunity[]

  @@index([normalizedEmail])
  @@index([normalizedPhone])
  @@index([lastName, firstName])
}

model PhoenixOrganization {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  address   String?
  website   String?
  type      String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts      PhoenixPerson[]
  bookings      PhoenixBooking[]
  registrations PhoenixRegistration[]
  opportunities PhoenixOpportunity[]
}

model PhoenixBooking {
  id             String   @id @default(uuid())
  serviceId      String
  childId        String?
  parentId       String?
  familyId       String?
  organizationId String?
  importBatchId  String?
  registrationId String?
  bookingDate    DateTime?
  amount         Float?
  sourceType     String
  sourceLabel    String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  service      PhoenixService       @relation(fields: [serviceId], references: [id])
  child        PhoenixPerson?       @relation("PhoenixBookingChild", fields: [childId], references: [id], onDelete: SetNull)
  parent       PhoenixPerson?       @relation("PhoenixBookingParent", fields: [parentId], references: [id], onDelete: SetNull)
  family       PhoenixFamily?       @relation(fields: [familyId], references: [id], onDelete: SetNull)
  organization PhoenixOrganization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  importBatch  PhoenixImportBatch?  @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  registration PhoenixRegistration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)
}

model PhoenixActivity {
  id             String   @id @default(uuid())
  serviceId      String
  name           String
  type           String
  description    String?
  defaultPrice   Float?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  service  PhoenixService  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  sessions PhoenixSession[]

  @@unique([serviceId, name])
}

model PhoenixSession {
  id          String   @id @default(uuid())
  activityId  String
  serviceId   String
  title       String
  kind        String
  startAt     DateTime?
  endAt       DateTime?
  dayOfWeek   String?
  timeLabel   String?
  location    String?
  level       String?
  capacity    Int?
  price       Float?
  instructor  String?
  sourceType  String?
  sourceLabel String?
  status      String   @default("OPEN")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  activity      PhoenixActivity       @relation(fields: [activityId], references: [id], onDelete: Cascade)
  service       PhoenixService        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  registrations PhoenixRegistration[]
  assignments   PhoenixInstructorAssignment[]

  @@index([kind])
  @@index([startAt])
  @@unique([serviceId, sourceType, sourceLabel, startAt])
}

model PhoenixRegistration {
  id             String   @id @default(uuid())
  sessionId      String
  childId        String?
  parentId       String?
  familyId       String?
  organizationId String?
  status         String   @default("REGISTERED")
  sourceType     String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  session      PhoenixSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  child        PhoenixPerson?       @relation("PhoenixRegistrationChild", fields: [childId], references: [id], onDelete: SetNull)
  parent       PhoenixPerson?       @relation("PhoenixRegistrationParent", fields: [parentId], references: [id], onDelete: SetNull)
  family       PhoenixFamily?       @relation(fields: [familyId], references: [id], onDelete: SetNull)
  organization PhoenixOrganization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  payments     PhoenixPayment[]
  bookings     PhoenixBooking[]

  @@index([status])
  @@index([sessionId])
}

model PhoenixPayment {
  id             String   @id @default(uuid())
  registrationId String
  expectedAmount Float    @default(0)
  paidAmount     Float    @default(0)
  balanceAmount  Float    @default(0)
  status         String   @default("UNKNOWN")
  method         String?
  dueAt          DateTime?
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  registration PhoenixRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
}

model PhoenixInstructor {
  id        String   @id @default(uuid())
  name      String   @unique
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments PhoenixInstructorAssignment[]
}

model PhoenixInstructorAssignment {
  id           String   @id @default(uuid())
  sessionId    String
  instructorId String
  role         String?
  fee          Float?
  notes        String?
  createdAt    DateTime @default(now())

  session    PhoenixSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  instructor PhoenixInstructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([sessionId, instructorId])
}

model PhoenixImportBatch {
  id           String   @id @default(uuid())
  filename     String
  importType   String
  status       String   @default("PREVIEW")
  rawRows      Json
  mapping      Json?
  rowCount      Int      @default(0)
  importedCount Int      @default(0)
  duplicateCount Int     @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bookings PhoenixBooking[]
}

model PhoenixOpportunity {
  id             String   @id @default(uuid())
  serviceId      String
  personId       String?
  familyId       String?
  organizationId String?
  type           String
  title          String
  reason         String
  status         String   @default("OPEN")
  priority       String   @default("MEDIUM")
  estimatedRevenue Float  @default(0)
  dueAt          DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  service       PhoenixService       @relation(fields: [serviceId], references: [id])
  person        PhoenixPerson?       @relation(fields: [personId], references: [id], onDelete: SetNull)
  family        PhoenixFamily?       @relation(fields: [familyId], references: [id], onDelete: SetNull)
  organization  PhoenixOrganization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  messages      PhoenixGeneratedMessage[]
}

model PhoenixGeneratedMessage {
  id            String   @id @default(uuid())
  opportunityId String
  channel       String
  subject       String?
  content       String
  status        String   @default("DRAFT")
  createdAt     DateTime @default(now())

  opportunity PhoenixOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
}
